# STAGE 1: Full developer compilation environment
FROM node:20-alpine AS builder
WORKDIR /usr/src/app
COPY package*.json ./
# Clean install all dependencies (production + devDependencies)
RUN npm ci
COPY . .

# STAGE 2: Secure, ultra-slim production runtime environment
FROM node:20-alpine AS runtime
ENV NODE_ENV=production

WORKDIR /usr/src/app
COPY package*.json ./
# Clean install ONLY production packages, stripping typescript/jest modules
RUN npm ci --only=production

# Copy active application files from the builder environment
COPY --from=builder /usr/src/app/app.js ./

# Enforce secure unprivileged user execution
USER node

EXPOSE 3000
CMD ["node", "app.js"]
