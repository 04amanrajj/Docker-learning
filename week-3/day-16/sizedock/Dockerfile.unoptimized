# Base image using Alpine
FROM node:20-alpine
WORKDIR /usr/src/app

COPY package*.json ./
RUN npm ci
COPY . .

# LAYER 1: Download/generate a heavy dummy asset (25MB) representing a downloaded tarball
RUN dd if=/dev/zero of=heavy-bundle.tar.gz bs=1M count=25

# LAYER 2: Clean up/delete the heavy asset in a separate instruction
# 🚨 GOTCHA: This does NOT recover the 25MB footprint from the history!
RUN rm heavy-bundle.tar.gz

EXPOSE 3000
CMD ["node", "app.js"]
