# Base image using Alpine
FROM node:20-alpine
WORKDIR /usr/src/app

COPY package*.json ./
RUN npm ci
COPY . .

# LAYER 1: Download/generate, use, and CLEAN UP in a single chained run command!
# ✓ This completely prevents the 25MB footprint from persisting in the final image history.
RUN dd if=/dev/zero of=heavy-bundle.tar.gz bs=1M count=25 && \
    echo "✓ Bundle processed and validated" && \
    rm heavy-bundle.tar.gz

EXPOSE 3000
CMD ["node", "app.js"]
